# Twilio (supports both naming conventions)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=

# Legacy Twilio naming (used as fallback)
# ACCOUNT_SID=
# AUTH_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Retell (signature validation)
RETELL_API_KEY=
RETELL_WEBHOOK_TOKEN=

# Save raw Retell webhook payloads locally for replay/debugging
SAVE_WEBHOOK_LOGS=false

# Workflow automation
# Default workflow sends the job to the technician once; the technician contacts the customer.
JOB_POLLING_ENABLED=false
CUSTOMER_CONFIRMATION_SMS_ENABLED=false

# Phone numbers

# Contractor phones
JOSE_PHONE=
MARIO_PHONE=
RAUL_PHONE=

# Contractor availability
# Jose is paused temporarily; set JOSE_ACTIVE=true to restore original order.
JOSE_ACTIVE=false
MARIO_ACTIVE=true
RAUL_ACTIVE=true

# Slack (replaces Eddie SMS when enabled)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=

# Dashboard slug (optional — random 8-char hex generated if not set)
DASHBOARD_SLUG=

# Database path (default: dispatch.db for local dev, /data/dispatch.db for prod)
DB_PATH=
