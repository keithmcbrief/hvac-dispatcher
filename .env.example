# Twilio (supports both naming conventions)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=

# Legacy Twilio naming (used as fallback)
# ACCOUNT_SID=
# AUTH_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Retell (signature validation)
RETELL_API_KEY=

# Save raw Retell webhook payloads locally for replay/debugging
SAVE_WEBHOOK_LOGS=false

# Phone numbers
EDDIE_PHONE=

# Contractor phones
JOSE_PHONE=
MARIO_PHONE=
RAUL_PHONE=

# Slack (replaces Eddie SMS when enabled)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=

# Dashboard slug (optional — random 8-char hex generated if not set)
DASHBOARD_SLUG=

# Database path (default: dispatch.db for local dev, /data/dispatch.db for prod)
DB_PATH=
